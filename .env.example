# TiendaOS Configuration
# Copy this to .env and adjust values

# Database
DATABASE_URL=sqlite:///./tiendaos.db
# For cloud/production PostgreSQL:
# DATABASE_URL=postgresql://user:pass@localhost:5432/tiendaos

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Store Identity
STORE_ID=store-1
STORE_NAME=Tienda Centro

# Auth
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480

# AI Configuration (toggle modules on/off)
AI_ENABLED=true
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# Optional: Claude API for complex queries
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# AI Modules (true/false)
AI_DEMAND_FORECAST=false
AI_INSIGHTS=false
AI_SMART_ALERTS=false
AI_CUSTOMER_INSIGHTS=false

# Cloud Sync (local install → cloud)
# Set IS_LOCAL_INSTANCE=true on local store installs to enable sync
IS_LOCAL_INSTANCE=false
CLOUD_API_URL=https://dylanlopez.com
CLOUD_SYNC_USER=admin
CLOUD_SYNC_PASSWORD=
SYNC_INTERVAL_SECONDS=300

# Receipt Printer
PRINTER_TYPE=thermal
PRINTER_NAME=default
PRINTER_PORT=/dev/usb/lp0         # USB on Linux. Use IP:9100 for network (e.g. 192.168.1.100:9100)

# Currency
CURRENCY=MXN
CURRENCY_SYMBOL=$
TAX_RATE=0.0
